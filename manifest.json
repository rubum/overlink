{
    "manifest_version": 3,
    "name": "Overlink",
    "version": "1.0",
    "description": "Open links in an elegant, in-page dialog without leaving your current tab.",
    "permissions": [
        "contextMenus",
        "activeTab",
        "scripting",
        "declarativeNetRequest",
        "sidePanel",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "ruleset_1",
                "enabled": true,
                "path": "rules.json"
            }
        ]
    }
}